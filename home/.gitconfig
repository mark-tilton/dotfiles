[user]
    name = Mark Tilton
    email = mark.tilton.a@gmail.com

[core]
    excludesfile = ~/.gitignore_global
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    line-numbers = true
    side-by-side = true

[merge]
    conflictstyle = zdiff3

[diff]
    colorMoved = default

[init]
    defaultBranch = main

[pull]
    rebase = false

[push]
    autoSetupRemote = true

[rerere]
    enabled = true

[fetch]
    prune = true
