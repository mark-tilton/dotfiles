#!/usr/bin/env bash

PLUGIN_DIR="$CONFIG_DIR/plugins"

# Kanagawa wave (matches bordersrc: crystalBlue accent, sumiInk4 muted)
BAR_COLOR=0xf01f1f28   # sumiInk1
FG=0xffdcd7ba          # fujiWhite
ACCENT=0xff7e9cd8      # crystalBlue
MUTED=0xff727169       # fujiGray
GREEN=0xff98bb6c       # springGreen
YELLOW=0xffc0a36e      # boatYellow2

sketchybar --bar \
	position=top \
	color=$BAR_COLOR \
	padding_left=8 \
	padding_right=8

# Height depends on whether a notched display is connected; recomputed on
# display changes by the bar_height watcher item below.
"$PLUGIN_DIR/bar_height.sh"

sketchybar --add item bar_height left \
	--set bar_height drawing=off script="$PLUGIN_DIR/bar_height.sh" \
	--subscribe bar_height display_change system_woke

sketchybar --default \
	icon.font="Maple Mono NF:Bold:14.0" \
	label.font="Maple Mono NF:SemiBold:13.0" \
	icon.color=$FG \
	label.color=$FG \
	padding_left=7 \
	padding_right=7 \
	icon.padding_left=6 \
	icon.padding_right=2 \
	label.padding_left=2 \
	label.padding_right=6

# ─── Left: AeroSpace workspaces (number + app icons), focused front app ───
sketchybar --add event aerospace_workspace_change
for sid in $(aerospace list-workspaces --all); do
	sketchybar --add item space."$sid" left \
		--subscribe space."$sid" aerospace_workspace_change front_app_switched \
		--set space."$sid" \
		icon="$sid" \
		icon.padding_left=10 \
		icon.font="Maple Mono NF:Bold:13.0" \
		label.font="sketchybar-app-font:Regular:15.0" \
		label.padding_right=10 \
		background.color=$ACCENT \
		background.corner_radius=6 \
		background.height=22 \
		background.drawing=off \
		script="$PLUGIN_DIR/aerospace.sh $sid" \
		click_script="aerospace workspace $sid"
done

sketchybar --add item front_app left \
	--set front_app \
	icon.drawing=off \
	label.color=$ACCENT \
	label.font="Maple Mono NF:Bold:13.0" \
	script="$PLUGIN_DIR/front_app.sh" \
	--subscribe front_app front_app_switched

# ─── Right (first added = rightmost) ───
sketchybar --add item clock right \
	--set clock update_freq=30 icon=󰃰 script="$PLUGIN_DIR/clock.sh"

sketchybar --add item battery right \
	--set battery update_freq=120 script="$PLUGIN_DIR/battery.sh" \
	--subscribe battery system_woke power_source_change

sketchybar --add item volume right \
	--set volume script="$PLUGIN_DIR/volume.sh" \
	--subscribe volume volume_change

sketchybar --add item brew_outdated right \
	--set brew_outdated icon=󰏖 icon.color=$YELLOW update_freq=3600 drawing=off \
	script="$PLUGIN_DIR/brew_outdated.sh"

# The graph fills its whole item (text drawn over it would overlap), so the
# readout is a separate fixed-width item placed flush against the graph's left.
sketchybar --add graph cpu right 60 \
	--set cpu update_freq=3 \
	icon.drawing=off label.drawing=off padding_left=0 \
	graph.color=$ACCENT graph.fill_color=0x447e9cd8 \
	script="$PLUGIN_DIR/cpu.sh"

sketchybar --add item cpu_text right \
	--set cpu_text icon=󰻠 icon.color=$MUTED \
	label="--%" label.color=$MUTED label.font="Maple Mono NF:SemiBold:11.0" \
	label.width=34 label.align=right padding_right=0

sketchybar --add item pomodoro right \
	--set pomodoro icon=󰔛 icon.color=$GREEN update_freq=1 drawing=off \
	script="$PLUGIN_DIR/pomodoro.sh" \
	click_script="$PLUGIN_DIR/pomodoro.sh toggle"

# Spotify fires a distributed notification on play/pause/track change
sketchybar --add event spotify_change com.spotify.client.PlaybackStateChanged
sketchybar --add item spotify right \
	--set spotify icon=󰓇 icon.color=$GREEN label.max_chars=35 drawing=off \
	update_freq=30 script="$PLUGIN_DIR/spotify.sh" \
	click_script="osascript -e 'tell application \"Spotify\" to playpause'" \
	--subscribe spotify spotify_change

sketchybar --update
